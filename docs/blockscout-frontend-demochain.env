# Blockscout frontend — DemoChain BY (same-origin API)
# Копировать на сервер: envs/common-frontend.env
# cp docs/blockscout-frontend-demochain.env /root/blockscout/docker-compose/envs/common-frontend.env
#
# Важно: браузер обращается к API по этому хосту. Должен совпадать с URL, по которому открывают эксплорер.

# App (страница открыта как http://82.26.171.108:4000)
NEXT_PUBLIC_APP_PROTOCOL=http
NEXT_PUBLIC_APP_HOST=82.26.171.108
NEXT_PUBLIC_APP_PORT=4000

# API — тот же хост и порт (запросы идут на тот же origin, nginx проксирует /api на бэкенд)
NEXT_PUBLIC_API_PROTOCOL=http
NEXT_PUBLIC_API_HOST=82.26.171.108
NEXT_PUBLIC_API_PORT=4000
# Проксировать запросы к API через Next.js (браузер ходит на тот же origin)
NEXT_PUBLIC_USE_NEXT_JS_PROXY=true

# Сеть
NEXT_PUBLIC_NETWORK_NAME=DemoChain BY
NEXT_PUBLIC_NETWORK_ID=2026
NEXT_PUBLIC_NETWORK_CURRENCY_SYMBOL=ETH
NEXT_PUBLIC_NETWORK_VERIFICATION_TYPE=mining

# Отключить чужую рекламу (по умолчанию Blockscout показывает баннеры и текстовые объявления)
NEXT_PUBLIC_AD_BANNER_PROVIDER=none
NEXT_PUBLIC_AD_TEXT_PROVIDER=none
